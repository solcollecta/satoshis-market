# ── AtomicSwapEscrow Web — Environment Variables ──────────────────────────────
#
# Copy this file to .env.local and fill in your values.
# All NEXT_PUBLIC_ vars are exposed to the browser bundle.
#
# OPNet does NOT have a separate "testnet" node yet.
# The shared testing environment is "regtest" at regtest.opnet.org.
# Use that for demos and integration testing.

# ── OPNet node ────────────────────────────────────────────────────────────────

# HTTP JSON-RPC endpoint for the OPNet node.
# Official public endpoints:
#   Regtest (shared test env): https://regtest.opnet.org
#   Mainnet:                   https://mainnet.opnet.org
NEXT_PUBLIC_OP_RPC_URL=https://regtest.opnet.org

# Bitcoin network that the node runs on: "regtest" or "mainnet"
# Must match the node pointed to by NEXT_PUBLIC_OP_RPC_URL.
NEXT_PUBLIC_OP_NETWORK=regtest

# ── Contract ──────────────────────────────────────────────────────────────────

# Deployed AtomicSwapEscrow contract address (bech32 / taproot format)
NEXT_PUBLIC_CONTRACT_ADDRESS=bcrt1p...

# ── UI ────────────────────────────────────────────────────────────────────────

# Maximum offerId to scan when listing offers on the home page (1..N)
NEXT_PUBLIC_MAX_OFFER_ID=50
